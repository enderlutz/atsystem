# Database
DATABASE_URL=postgresql://localhost/atsystem

# Auth (generate with: openssl rand -hex 32)
AUTH_SECRET=change-me-in-production

# GoHighLevel
GHL_API_KEY=your_ghl_private_integration_token
GHL_LOCATION_ID=your_ghl_location_id
OWNER_GHL_CONTACT_ID=your_alan_ghl_contact_id

# Resend (Email)
RESEND_API_KEY=re_your_resend_api_key
OWNER_EMAIL=owner@atpressurewash.com

# Frontend URLs
FRONTEND_URL=http://localhost:3000
PROPOSAL_BASE_URL=http://localhost:3000

# Google Calendar (service account JSON — paste entire contents as single line)
GOOGLE_CALENDAR_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
GOOGLE_CALENDAR_ID=primary

# Google Maps (for satellite view on lead detail)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Stripe (for $50 deposit on proposal booking)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key

# GHL pipeline stage to move opportunities to when a booking is confirmed.
# Find in GHL: Settings → Pipelines → hover over stage → copy ID. Leave blank to disable.
GHL_BOOKED_STAGE_ID=
